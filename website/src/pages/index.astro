---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Hecate is a local-first AI gateway and agent console. Route cloud/local models, run Hecate-owned tool agents, supervise Codex / Claude Code / Cursor, and keep every decision observable."
    />
    <link rel="icon" href="/brand/png/mark-trivium-black-64.png" sizes="64x64" />
    <title>Hecate - AI Gateway and Agent Runtime</title>
  </head>
  <body>
    <main class="page-shell">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero__backdrop" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>

        <div class="hero__copy">
          <p class="eyebrow">ai gateway · agent runtime</p>
          <h1 id="hero-title">hecate</h1>
          <p class="lede">
            Local-first AI gateway and agent console. Route cloud/local models,
            run Hecate-owned tool agents, supervise Codex / Claude Code / Cursor,
            and keep every decision observable.
          </p>

          <div class="hero__actions" aria-label="Primary actions">
          <a
            class="button button--primary"
            href="https://github.com/hecatehq/hecate/releases"
          >
            Download
          </a>
            <a class="button button--ghost" href="https://github.com/hecatehq/hecate">
              GitHub
            </a>
          </div>
        </div>

        <div class="hero__symbol" aria-hidden="true">
          <div class="symbol-ring">
            <img src="/brand/mark-trivium.svg" alt="" />
          </div>
          <div class="signal-line signal-line--top"></div>
          <div class="signal-line signal-line--left"></div>
          <div class="signal-line signal-line--right"></div>
        </div>
      </section>
    </main>

  </body>
</html>
