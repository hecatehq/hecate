{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "sh.hecate.mobile",
  "build": {
    "frontendDist": "../mobile"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Hecate",
        "incognito": true,
        "userAgent": "HecateMobile"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' data:; style-src 'self'; script-src 'self'; font-src 'self'; object-src 'none'; base-uri 'none'; frame-ancestors 'none'",
      "freezePrototype": true
    }
  },
  "bundle": {
    "createUpdaterArtifacts": false,
    "externalBin": [],
    "icon": [],
    "iOS": {
      "minimumSystemVersion": "15.0",
      "bundleVersion": "6.0.4"
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        {
          "scheme": [
            "hecate-mobile"
          ],
          "appLink": false
        }
      ]
    },
    "shell": null,
    "updater": null
  }
}
