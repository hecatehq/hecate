{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability granted to the main application window",
  "windows": ["main"],
  "platforms": ["linux", "macOS", "windows"],
  "remote": {
    "urls": ["http://127.0.0.1:*/*"]
  },
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "allow-cloud-connection-start",
    "allow-cloud-connection-status",
    "allow-cloud-connection-stop",
    "allow-cloud-connection-sign-out",
    "allow-open-workspace-target",
    "allow-set-update-badge",
    "allow-take-pending-desktop-update-check",
    "log:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "http://*" }, { "url": "https://*" }, { "url": "mailto:*" }]
    },
    "process:allow-restart",
    "updater:default"
  ]
}
