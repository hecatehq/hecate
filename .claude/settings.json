{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Shared, repo-owned baseline for Claude Code permissions only. Canonical agent guidance lives in docs-ai/; .claude/settings.local.json may hold per-machine permissions/session state but must not define project rules. Keep this file conservative: read-only git, build, test, and lint commands only. Anything destructive (git push, rm -rf, git reset --hard) stays out of the shared allowlist on purpose.",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git ls-files:*)",
      "Bash(git rev-parse:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git stash list:*)",

      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(go mod:*)",
      "Bash(go list:*)",
      "Bash(go env:*)",
      "Bash(go version)",
      "Bash(go fmt:*)",

      "Bash(bun install)",
      "Bash(bun run:*)",
      "Bash(bun x:*)",
      "Bash(bunx:*)",
      "Bash(bun add:*)",
      "Bash(bun remove:*)",

      "Bash(make:*)",

      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(file:*)",

      "Bash(curl -s http://127.0.0.1:*)",
      "Bash(curl -s http://localhost:*)"
    ]
  }
}
