{
  "name": "hecate-ui",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.3.13"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsgo -b",
    "build": "bun run typecheck && vite build",
    "preview": "vite preview",
    "lint": "oxlint -c ../.oxlintrc.json --type-aware src e2e vite.config.ts vitest.config.ts playwright.config.ts",
    "format": "oxfmt --write src e2e vite.config.ts vitest.config.ts playwright.config.ts index.html",
    "format:check": "oxfmt --check src e2e vite.config.ts vitest.config.ts playwright.config.ts index.html",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "capture-screenshots": "NODE_PATH=$PWD/node_modules bun run ../scripts/capture-screenshots.ts"
  },
  "dependencies": {
    "@dev.icons/react": "^1.1.0",
    "@pierre/diffs": "1.2.7",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@typescript/native-preview": "beta",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^29.0.2",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.65.0",
    "oxlint-tsgolint": "0.23.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
